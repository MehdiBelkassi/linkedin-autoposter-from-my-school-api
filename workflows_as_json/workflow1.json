      "parameters": {
        "jsCode": "// Get the latest project from the HTTP Request node\nconst latestProject = $input.first().json;\nconst newMarkedAt = latestProject.marked_at;\n\n// Read the saved value\nconst data = $getWorkflowStaticData('global');\nconst lastMarkedAt = data.last_marked_at;\n\n// If same as last time, stop the workflow\nif (lastMarkedAt === newMarkedAt) {\n  return [];  // empty output = workflow stops here\n}\n\n// If new validation, save the new value and continue\ndata.last_marked_at = newMarkedAt;\n\n// Pass the project data to the next node\nreturn [\n  {\n    json: {\n      project_name: latestProject.project.name,\n      final_mark: latestProject.final_mark,\n      marked_at: newMarkedAt,\n      project_id: latestProject.project.id\n    }\n  }\n];"
